   TColor *color; // for color definition with alpha
   ci = TColor::GetColor("#ff0000");
   hist1__1->SetLineColor(ci);
   hist1__1->GetXaxis()->SetLabelFont(42);
   hist1__1->GetXaxis()->SetTitleOffset(1);
   hist1__1->GetXaxis()->SetTitleFont(42);
   hist1__1->GetYaxis()->SetLabelFont(42);
   hist1__1->GetYaxis()->SetTitleFont(42);
   hist1__1->GetZaxis()->SetLabelFont(42);
   hist1__1->GetZaxis()->SetTitleOffset(1);
   hist1__1->GetZaxis()->SetTitleFont(42);
   hist1__1->Draw("");
}
